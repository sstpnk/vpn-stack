# Server configuration
WG_HOST=xxx.xxx.xxx.xxx
WG_EASY_PASSWORD=your_secure_password
WG_PORT=51820
WG_MTU=1280
WG_PERSISTENT_KEEPALIVE=25
# Optional override. Empty value uses the fork's split-tunnel default.
WG_ALLOWED_IPS=
AMNEZIA_JC=10
AMNEZIA_JMIN=64
AMNEZIA_JMAX=200
AMNEZIA_S1=64
AMNEZIA_S2=64
AMNEZIA_H1=1000-12999
AMNEZIA_H2=13000-24999
AMNEZIA_H3=25000-36999
AMNEZIA_H4=37000-50000
AMNEZIA_I1='<b 0x160301>'
AMNEZIA_I2='<r 3><b 0x0303><r 32>'
AMNEZIA_I3='<b 0x00><r 5>'
AMNEZIA_I4='<r 40>'
AMNEZIA_I5='<b 0xC0000000><r 8><b 0x04><r 100>'
XRAY_PORT=8443
XRAY_PUBLIC_HOST=
XRAY_SERVER_NAME=www.google.com
XRAY_FINGERPRINT=randomized

# Telegram bot (optional - remove or leave empty to disable)
BOT_TOKEN=your_bot_token_from_botfather
ALLOWED_USERNAMES=your_telegram_username

# Suppress buildx warning (optional)
DOCKER_COMPOSE_EXPERIMENTAL=false
