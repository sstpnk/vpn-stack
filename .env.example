# Server configuration
WG_HOST=xxx.xxx.xxx.xxx
WG_EASY_PASSWORD=your_secure_password
WG_PORT=51820
WG_MTU=1280
# Optional override. Empty value uses the fork's split-tunnel default.
WG_ALLOWED_IPS=
AMNEZIA_JC=9
AMNEZIA_JMIN=50
AMNEZIA_JMAX=1000
AMNEZIA_S1=33
AMNEZIA_S2=18
AMNEZIA_H1=1556852380
AMNEZIA_H2=854724827
AMNEZIA_H3=1373297535
AMNEZIA_H4=1443617385
AMNEZIA_I1=4
AMNEZIA_I2=4
AMNEZIA_I3=3
AMNEZIA_I4=0
AMNEZIA_I5=0
XRAY_PORT=443

# Telegram bot (optional - remove or leave empty to disable)
BOT_TOKEN=your_bot_token_from_botfather
ALLOWED_USERNAMES=your_telegram_username

# Suppress buildx warning (optional)
DOCKER_COMPOSE_EXPERIMENTAL=false
